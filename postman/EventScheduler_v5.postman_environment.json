{
  "id": "es-v5-env-2026",
  "name": "Event Scheduler v5 – Local",
  "_postman_meta": {
    "hasPassword": false
  },
  "values": [
    {
      "key": "base_url",
      "value": "https://event-scheduler-application-production.up.railway.app",
      "enabled": true,
      "type": "default",
      "description": "Production: Railway deployment. For local dev switch to http://localhost:3000"
    },
    {
      "key": "firebase_api_key",
      "value": "your_firebase_web_api_key",
      "enabled": true,
      "type": "default",
      "description": "Firebase Web API key (NOT the service account key). Project Settings → General → Web API Key. Required for auto token refresh."
    },
    {
      "key": "admin_email",
      "value": "your_admin@example.com",
      "enabled": true,
      "type": "default",
      "description": "Firebase user email with admin role. Admin is promoted in MongoDB: db.users.updateOne({email:'...'},{$set:{role:'admin'}})"
    },
    {
      "key": "admin_password",
      "value": "your_admin_password",
      "enabled": true,
      "type": "secret",
      "description": "Firebase password for admin user."
    },
    {
      "key": "admin_token",
      "value": "PASTE_ADMIN_TOKEN_OR_LET_AUTO_REFRESH",
      "enabled": true,
      "type": "default",
      "description": "Firebase ID token for admin. Auto-refreshed by pre-request script if firebase_api_key is set."
    },
    {
      "key": "member_email",
      "value": "your_member@example.com",
      "enabled": true,
      "type": "default",
      "description": "Firebase user email with member role (default for new sign-ups)."
    },
    {
      "key": "member_password",
      "value": "your_member_password",
      "enabled": true,
      "type": "secret",
      "description": "Firebase password for member user."
    },
    {
      "key": "member_token",
      "value": "PASTE_MEMBER_TOKEN_OR_LET_AUTO_REFRESH",
      "enabled": true,
      "type": "default",
      "description": "Firebase ID token for member. Auto-refreshed by pre-request script."
    },
    {
      "key": "event_id",
      "value": "",
      "enabled": true,
      "type": "default",
      "description": "Auto-populated by 'POST /api/events create' test."
    },
    {
      "key": "bypass_event_id",
      "value": "",
      "enabled": true,
      "type": "default",
      "description": "Auto-populated by ignoreConflicts=true test."
    },
    {
      "key": "invitation_id",
      "value": "",
      "enabled": true,
      "type": "default",
      "description": "Auto-populated by invite test or attendees fallback."
    },
    {
      "key": "_admin_token_expiry",
      "value": "0",
      "enabled": true,
      "type": "default",
      "description": "Internal: epoch ms when admin token expires. Managed by pre-request."
    },
    {
      "key": "_member_token_expiry",
      "value": "0",
      "enabled": true,
      "type": "default",
      "description": "Internal: epoch ms when member token expires. Managed by pre-request."
    }
  ]
}