# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/event-scheduler

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Admin SDK
# Option A: Paste the contents of your serviceAccountKey.json as a single-line
#            JSON string (escape double-quotes if needed).
# Option B: Leave blank to use Application Default Credentials (GCP / emulator).
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=your-firebase-project-id

# ─────────────────────────────────────────────────────────────────────────────
# CORS – comma-separated list of allowed origins.
# Leave blank in development to allow all origins.
# In production, ALWAYS set this; otherwise all cross-origin requests are denied.
# ─────────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI (optional – AI endpoints return 503 when not set)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
